generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AGENT
}

enum OrderStatus {
  NEW
  CONFIRMED
  CANCELLED
  CALL_LATER
  NO_ANSWER_1
  NO_ANSWER_2
  NO_ANSWER_3
  VOICEMAIL
  SHIPPING_QUEUE
  SHIPPED
  DELIVERED
  RETURNED
}

enum DeliveryProvider {
  AMEEX
  MOCK
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  role         UserRole       @default(AGENT)
  isWorking    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  assigned     Order[]        @relation("AssignedAgent")
  attempts     CallAttempt[]
  sessions     AgentSession[]
  upsells      Upsell[]       @relation("UpsellAgent")
}

model Order {
  id              String           @id @default(cuid())
  externalOrderId String?
  customerName    String
  phone           String
  city            String
  product         String
  price           Decimal          @db.Decimal(10, 2)
  note            String?
  source          String           @default("google_sheets")
  status          OrderStatus      @default(NEW)
  assignedAgentId String?
  scheduledAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  returnedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assignedAgent   User?            @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  callAttempts    CallAttempt[]
  statusHistory   OrderStatusLog[]
  upsells         Upsell[]
  deliveries      DeliveryEvent[]

  @@index([phone])
  @@index([status])
}

model CallAttempt {
  id        String      @id @default(cuid())
  orderId   String
  agentId   String
  attemptNo Int
  status    OrderStatus
  notes     String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  agent     User        @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  changedAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Upsell {
  id          String   @id @default(cuid())
  orderId     String
  agentId     String
  description String
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  deliveredAt DateTime?
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  agent       User     @relation("UpsellAgent", fields: [agentId], references: [id], onDelete: Cascade)
}

model DeliveryEvent {
  id          String           @id @default(cuid())
  orderId      String
  provider     DeliveryProvider @default(MOCK)
  externalId   String?
  status       OrderStatus
  payload      Json?
  createdAt    DateTime         @default(now())
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model AdMetric {
  id         String   @id @default(cuid())
  date       DateTime
  spendMad   Decimal  @db.Decimal(10, 2)
  leads      Int
  sales      Int
  notes      String?
  createdAt  DateTime @default(now())

  @@unique([date])
}

model AgentSession {
  id        String    @id @default(cuid())
  agentId   String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  agent     User      @relation(fields: [agentId], references: [id], onDelete: Cascade)
}
